# ==============================================================================
# ملف: .env.example (نموذج لإعدادات البيئة)
# الوصف: قم بنسخ هذا الملف إلى .env وإضافة قيمك الخاصة
# ==============================================================================

# معرّف البوت من BotFather في Telegram
BOT_TOKEN=your_bot_token_here

# رابط قاعدة البيانات من Neon.tech
DATABASE_URL=postgresql://username:password@hostname:port/database_name?sslmode=require

# معرف القناة في Telegram (مثال: -1001234567890)
CHANNEL_ID=-1001234567890

# معرفات الإداريين (مفصولة بفواصل)
ADMIN_IDS=123456789,987654321

# رابط التطبيق على Render.com
APP_URL=https://your-app-name.onrender.com

# سر الويبهاوك (اختياري)
WEBHOOK_SECRET=your_webhook_secret_here

# المنفذ (عادة 10000 لـ Render)
PORT=10000